Toast {{
    background: {base};
    border-style: solid;
    border-width: 1px;
    border-left-width: 10px;
}}
Toast > QLabel {{
    padding: 2px;
    padding-left: 12px;
    font-size: 16px;
}}
Toast[toast_type=success] {{
    border-color: {success};
}}
Toast[toast_type=warning] {{
    border-color: {warning};
}}
Toast[toast_type=error] {{
    border-color: {error};
}}
